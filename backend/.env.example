# Backend environment configuration example
# Copy this file to .env and adjust values as needed.

# Database: SQLite default (no Docker needed)
DATABASE_URL=sqlite:///./storage/app.db

# Database: PostgreSQL via docker-compose
# DATABASE_URL=postgresql://guitar:guitar@localhost:5432/guitar

# Storage: local filesystem default
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# Storage: MinIO (when STORAGE_TYPE=minio)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=guitar
# MINIO_SECURE=false

DEBUG=true
