# Backend environment configuration example
# Copy this file to .env and adjust values as needed.

# Database: SQLite default (no Docker needed)
DATABASE_URL=sqlite:///./storage/app.db

# Database: PostgreSQL via docker-compose
# DATABASE_URL=postgresql://guitar:guitar@localhost:5432/guitar

# Storage: local filesystem default
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
MAX_VIDEO_UPLOAD_BYTES=1073741824
MAX_SCORE_UPLOAD_BYTES=10485760

# Comma-separated browser origins. Avoid "*" when credentials are enabled.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false

# Storage: MinIO (when STORAGE_TYPE=minio)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=guitar
# MINIO_SECURE=false

DEBUG=true
