# Backend environment configuration example
# Copy this file to .env and adjust values as needed.

# Database: SQLite default (no Docker needed)
DATABASE_URL=sqlite:///./storage/app.db

# Database: PostgreSQL via docker-compose
# DATABASE_URL=postgresql://guitar:guitar@localhost:5432/guitar

# Storage: local filesystem default
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
MAX_VIDEO_UPLOAD_BYTES=1073741824
MAX_SCORE_UPLOAD_BYTES=10485760

# Comma-separated browser origins. Avoid "*" when credentials are enabled.
# Include Vite dev (5173) and preview (4173) ports for local frontend development.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
CORS_ALLOW_CREDENTIALS=false

# Storage: MinIO (when STORAGE_TYPE=minio)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=guitar
# MINIO_SECURE=false

# Baidu Speech Recognition (short speech API)
# Get credentials from https://ai.baidu.com/tech/speech
BAIDU_SPEECH_APP_ID=
BAIDU_SPEECH_API_KEY=
BAIDU_SPEECH_SECRET_KEY=
BAIDU_SPEECH_DEV_PID=1537
# 1537 = Mandarin, 1737 = English

# LLM for natural-language command parsing (OpenAI-compatible endpoint)
# Supports Baidu Qianfan, DeepSeek, Zhipu, OpenAI, etc.
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

DEBUG=true
